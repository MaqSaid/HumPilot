{
  "enabled": true,
  "name": "Run Tests After Task",
  "description": "Runs the test suite after task completion to verify nothing is broken",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "npx vitest --run 2>&1 | tail -20"
  }
}